// ===== Water Sensor (phia trai) =====
#define WATER_SENSOR_PIN     36   // chan S - bat buoc ADC
#define WATER_SENSOR_VCC_PIN 32   // chan + - set HIGH de cap nguon

// ===== Relay (IN o phia phai, DC+/DC- ve VIN/GND phia trai) =====
#define RELAY_PIN 5

void setup() {
  Serial.begin(115200);
  delay(500);

  // Cap nguon cho water sensor qua GPIO32
  pinMode(WATER_SENSOR_VCC_PIN, OUTPUT);
  digitalWrite(WATER_SENSOR_VCC_PIN, HIGH);

  // Relay
  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);

  Serial.println("=== Bat dau test Water Sensor + Relay + Bom ===");
}

void loop() {
  Serial.println("------------------------");

  // 1. Water sensor
  int waterValue = analogRead(WATER_SENSOR_PIN);
  Serial.print("Water sensor: ");
  Serial.println(waterValue);

  // 2. Relay - bat/tat bom de nghe tieng click va quan sat bom chay
  digitalWrite(RELAY_PIN, HIGH);
  Serial.println("Relay/Bom: ON");
  delay(1500);

  digitalWrite(RELAY_PIN, LOW);
  Serial.println("Relay/Bom: OFF");
  delay(1500);
}
