// ===== Pin definitions =====
#define DOUT_PIN             23
#define SCK_PIN              14
#define WATER_SENSOR_PIN     36
#define WATER_SENSOR_VCC_PIN 32
#define RELAY_PIN            25
#define SERVO_PIN            13

// ===== Nguong =====
#define WATER_MIN         120
#define WATER_MAX         1300
#define WATER_LOW_PCT     30
#define WATER_HIGH_PCT    70
#define FOOD_LOW_GRAM     50
#define SCALE_FACTOR      400.0
#define PUMP_MAX_ATTEMPTS 20

HX711 scale;
Servo myServo;
LiquidCrystal_I2C lcd(0x27, 16, 2);
BlynkTimer timer;

// ===== Doc muc nuoc (%) =====
int readWaterLevel() {
  digitalWrite(WATER_SENSOR_VCC_PIN, HIGH);
  delay(100);
  int raw = analogRead(WATER_SENSOR_PIN);
  digitalWrite(WATER_SENSOR_VCC_PIN, LOW);
  Serial.print("RAW water: ");
  Serial.println(raw);
  int pct = map(raw, WATER_MIN, WATER_MAX, 0, 100);
  return constrain(pct, 0, 100);
}

// ===== Doc trong luong thuc an =====
float readFoodWeight() {
  if (!scale.is_ready()) return -1;
  return scale.get_units(10);
}

// ===== Hien thi LCD =====
void updateLCD(int waterPct, float foodGram, String status) {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("F:");
  lcd.print((int)foodGram);
  lcd.print("g W:");
  lcd.print(waterPct);
  lcd.print("%");
  lcd.setCursor(0, 1);
  lcd.print(status);
}

// ===== Bom nuoc =====
void pumpWater() {
  Serial.println("Low Water -> Start Pump");
  Blynk.logEvent("water_low");
  Blynk.virtualWrite(V3, "Refilling Water");
  lcd.setCursor(0, 1);
  lcd.print("Refilling Water ");

  int pct = readWaterLevel();
  int attempts = 0;

  while (pct < WATER_HIGH_PCT && attempts < PUMP_MAX_ATTEMPTS) {
    digitalWrite(RELAY_PIN, HIGH);
    Blynk.virtualWrite(V5, "ON");
    Blynk.run(); // giu ket noi blynk trong luc bom
    delay(500);
    pct = readWaterLevel();
    Serial.print("Pumping... Water: ");
    Serial.print(pct);
    Serial.println("%");
    attempts++;
  }

  digitalWrite(RELAY_PIN, LOW);
  Blynk.virtualWrite(V5, "OFF");

  if (attempts >= PUMP_MAX_ATTEMPTS) {
    Serial.println("Warning: Pump Timeout");
    Blynk.virtualWrite(V3, "Check Pump!");
    lcd.setCursor(0, 1);
    lcd.print("Check Pump!     ");
    delay(1500);
  } else {
    Serial.println("Water Full -> Stop Pump");
  }
  delay(1000);
  Blynk.virtualWrite(V8, "Just Now");
}

// ===== Nha thuc an =====
void dispenseFood() {
  Serial.println("Low Food -> Dispensing");
  Blynk.logEvent("food_low");
  Blynk.virtualWrite(V3, "Dispensing Food");
  lcd.setCursor(0, 1);
  lcd.print("Dispensing Food ");

  myServo.write(90);
  Blynk.run();
  delay(1500);
  myServo.write(0);
  delay(1000);

  Serial.println("Food Dispensed");
  Blynk.virtualWrite(V7, "Just Now");
  delay(1000);
}

// ===== Blynk: nut bam servo thu cong (V2) =====
BLYNK_WRITE(V2) {
  if (param.asInt() == 1) {
    dispenseFood();
  }
}

// ===== Blynk: nut bam bom thu cong (V4) =====
BLYNK_WRITE(V4)
{
  if (param.asInt())
  {
    digitalWrite(RELAY_PIN, HIGH);

    Blynk.virtualWrite(V3, "Manual Pump");
    Blynk.virtualWrite(V5, "ON");
  }
  else
  {
    digitalWrite(RELAY_PIN, LOW);

    Blynk.virtualWrite(V3, "Monitoring");
    Blynk.virtualWrite(V5, "OFF");
  }
}

// ===== Ham chay dinh ky (thay cho delay 60s) =====
void checkAndUpdate() {
  Serial.println("========================");

  int waterPct = readWaterLevel();
  float foodGram = readFoodWeight();

  Serial.print("Water: "); Serial.print(waterPct); Serial.println("%");
  Serial.print("Food: "); Serial.print(foodGram); Serial.println("g");

  Blynk.virtualWrite(V0, waterPct);
  Blynk.virtualWrite(V1, foodGram);
  Blynk.virtualWrite(V6, "🟢 Online");

  updateLCD(waterPct, foodGram, "Monitoring...");

  if (waterPct < WATER_LOW_PCT) {
    pumpWater();
  }

  if (foodGram >= 0 && foodGram < FOOD_LOW_GRAM) {
    dispenseFood();
  }

  waterPct = readWaterLevel();
  foodGram = readFoodWeight();
  updateLCD(waterPct, foodGram, "OK - Ready");
  Blynk.virtualWrite(V3, "Monitoring");
}

void setup() {
  Serial.begin(115200);
  delay(500);

  // Water sensor
  pinMode(WATER_SENSOR_VCC_PIN, OUTPUT);
  digitalWrite(WATER_SENSOR_VCC_PIN, LOW);

  // Relay
  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);

  // Servo
  myServo.attach(SERVO_PIN);
  myServo.write(0);

  // Load cell
  scale.begin(DOUT_PIN, SCK_PIN);
  scale.set_scale(SCALE_FACTOR);
  scale.tare();

  // LCD
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("Pet Feeder IoT");
  lcd.setCursor(0, 1);
  lcd.print("Connecting...");

  // Blynk
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  Blynk.virtualWrite(V6, "🟢 Online");
  Blynk.virtualWrite(V5, "OFF");
  Blynk.virtualWrite(V7, "--:--");
  Blynk.virtualWrite(V8, "--:--");
  Blynk.logEvent("device_online");

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Pet Feeder IoT");
  lcd.setCursor(0, 1);
  lcd.print("Ready!");
  delay(1000);

  // Timer chay moi 60 giay, khong block Blynk.run()
  timer.setInterval(60000L, checkAndUpdate);

  Serial.println("=== Pet Feeder IoT Ready ===");
}

void loop() {
  Blynk.run();
  timer.run();
}
