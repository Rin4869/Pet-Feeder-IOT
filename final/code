#include <HX711.h>
#include <ESP32Servo.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// ===== HX711 / Load cell =====
#define DOUT_PIN 23
#define SCK_PIN  14

// ===== Water Sensor =====
#define WATER_SENSOR_PIN     36
#define WATER_SENSOR_VCC_PIN 32

// ===== Relay + Bom =====
#define RELAY_PIN 25

// ===== Servo =====
#define SERVO_PIN 13

// ===== Nguong =====
#define WATER_MIN       120
#define WATER_MAX      1300
#define WATER_LOW_PCT   30
#define WATER_HIGH_PCT  70
#define FOOD_LOW_GRAM   50
#define SCALE_FACTOR    400.0  // chinh lai sau khi calibrate
#define PUMP_MAX_ATTEMPTS 20   // toi da ~10s bom, tranh ket vong lap

HX711 scale;
Servo myServo;
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ===== Doc muc nuoc (%) =====
int readWaterLevel() {
  digitalWrite(WATER_SENSOR_VCC_PIN, HIGH);
  delay(100);
  int raw = analogRead(WATER_SENSOR_PIN);
  digitalWrite(WATER_SENSOR_VCC_PIN, LOW);
  int pct = map(raw, WATER_MIN, WATER_MAX, 0, 100);
  return constrain(pct, 0, 100);
}

// ===== Doc trong luong thuc an (gram) =====
float readFoodWeight() {
  if (!scale.is_ready()) return -1;
  return scale.get_units(10);
}

// ===== Hien thi len LCD =====
void updateLCD(int waterPct, float foodGram, String status) {

  lcd.clear();

  lcd.setCursor(0, 0);
  lcd.print("F:");
  lcd.print((int)foodGram);
  lcd.print("g ");

  lcd.print("W:");
  lcd.print(waterPct);
  lcd.print("%");

  lcd.setCursor(0, 1);
  lcd.print(status);
}

// ===== Bom nuoc cho den khi dat nguong (co gioi han thoi gian) =====
void pumpWater() {
  Serial.println("Low Water -> Start Pump");
  lcd.setCursor(0, 1);
  lcd.print("Refilling Water");

  int pct = readWaterLevel();
  int attempts = 0;

  while (pct < WATER_HIGH_PCT && attempts < PUMP_MAX_ATTEMPTS) {
    digitalWrite(RELAY_PIN, HIGH);
    delay(500);
    pct = readWaterLevel();
    Serial.print("Pumping... Water: ");
    Serial.print(pct);
    Serial.println("%");
    attempts++;
  }

  digitalWrite(RELAY_PIN, LOW);

  if (attempts >= PUMP_MAX_ATTEMPTS) {
    Serial.println("Warning: Pump Timeout");
    lcd.setCursor(0, 1);
    lcd.print("Check Pump");
    delay(1500);
  } else {
    Serial.println("Water Full -> Stop Pump");
  }
  delay(1000);
}

// ===== Nha thuc an bang servo =====
void dispenseFood() {
  Serial.println("Low Food -> Dispensing");
  lcd.setCursor(0, 1);
  lcd.print("Dispensing Food");

  myServo.write(90);
  delay(1500);
  myServo.write(0);
  delay(1000);

  Serial.println("Food Dispensed");
  delay(1000);
}

void setup() {
  Serial.begin(115200);
  delay(500);

  // Water sensor
  pinMode(WATER_SENSOR_VCC_PIN, OUTPUT);
  digitalWrite(WATER_SENSOR_VCC_PIN, LOW);

  // Relay
  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);

  // Servo
  myServo.attach(SERVO_PIN);
  myServo.write(0);

  // Load cell
  scale.begin(DOUT_PIN, SCK_PIN);
  scale.set_scale(SCALE_FACTOR);
  scale.tare();

  // LCD - hien thi ngay khi khoi dong
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("Pet Feeder IoT");
  lcd.setCursor(0, 1);
  lcd.print("Initializing...");
  delay(1500);

  Serial.println("=== Pet Feeder IoT Ready ===");
}

void loop() {
  Serial.println("========================");

  // 1. Doc sensor va hien thi LCD NGAY LAP TUC (uu tien)
  int waterPct = readWaterLevel();
  float foodGram = readFoodWeight();

  Serial.print("Water Level: ");
  Serial.print(waterPct);
  Serial.println("%");
  Serial.print("Food Weight: ");
  Serial.print(foodGram);
  Serial.println("g");

  updateLCD(waterPct, foodGram, "");
  delay(800); // cho nguoi xem kip doc man hinh

  // 2. Xu ly bom nuoc neu can (LCD tu cap nhat trang thai ben trong)
  if (waterPct < WATER_LOW_PCT) {
    pumpWater();
  }

  // 3. Xu ly nha thuc an neu can (LCD tu cap nhat trang thai ben trong)
  if (foodGram >= 0 && foodGram < FOOD_LOW_GRAM) {
    dispenseFood();
  }

  // 4. Hien thi trang thai cuoi cung sau khi xu ly xong
  waterPct = readWaterLevel();
  foodGram = readFoodWeight();
  updateLCD(waterPct, foodGram, "");

  Serial.println("Waiting 10s minute...");
  delay(10000);
}
