// ===================================================
// LOAD PROFILE — 1 JSON request + retry 3 lan
// + enterErrorState khi that bai
// ===================================================

void loadProfile(String profileId) {
  if (profileId == activeProfileId && activeProfile.name != "Default") return;

  if (!firebaseReady()) {
    Serial.println(F("Firebase not ready, skip loadProfile"));
    enterErrorState("Profile Error");
    return;
  }

  String base    = "/profiles/" + profileId;
  bool   ok      = false;
  int    retries = 0;

  FirebaseJson     json;
  FirebaseJsonData result;

  // Retry toi da 3 lan
  while (!ok && retries < 3) {
    if (Firebase.RTDB.getJSON(&fbdo, base)) {
      ok = true;
    } else {
      retries++;
      Serial.print(F("Profile load retry: "));
      Serial.println(retries);
      delay(500);
    }
  }

  if (!ok) {
    Serial.println(F("Profile load failed after 3 retries"));
    enterErrorState("Profile Error");
    return;
  }

  // Parse JSON — chi apply khi tat ca thanh cong
  json.setJsonData(fbdo.jsonString());

  String newName    = activeProfile.name;
  int    newFoodLow = activeProfile.foodLowGram;
  int    newFoodTgt = activeProfile.foodTargetGram;
  int    newWatLow  = activeProfile.waterLow;
  int    newWatFill = activeProfile.waterRefill;
  bool   parseOk    = true;

  if (json.get(result, "name") && result.success)
    newName = result.stringValue;
  else parseOk = false;

  if (parseOk && json.get(result, "foodLow") && result.success)
    newFoodLow = result.intValue;
  else parseOk = false;

  if (parseOk && json.get(result, "foodTarget") && result.success)
    newFoodTgt = result.intValue;
  else parseOk = false;

  if (parseOk && json.get(result, "waterLow") && result.success)
    newWatLow = result.intValue;
  else parseOk = false;

  if (parseOk && json.get(result, "waterRefill") && result.success)
    newWatFill = result.intValue;
  else parseOk = false;

  if (!parseOk) {
    Serial.println(F("Profile JSON parse failed"));
    enterErrorState("Profile Error");
    return;
  }

  // Apply profile
  activeProfile.name          = newName;
  activeProfile.foodLowGram   = newFoodLow;
  activeProfile.foodTargetGram = newFoodTgt;
  activeProfile.waterLow      = newWatLow;
  activeProfile.waterRefill   = newWatFill;
  activeProfileId             = profileId;

  // Ghi activeProfile len Firebase
  if (firebaseReady())
    Firebase.RTDB.setString(&fbdo, "/activeProfile", profileId);

  Serial.print(F("Profile: "));  Serial.println(activeProfile.name);
  Serial.print(F("foodLow: "));  Serial.println(activeProfile.foodLowGram);
  Serial.print(F("foodTgt: "));  Serial.println(activeProfile.foodTargetGram);
  Serial.print(F("watLow: "));   Serial.println(activeProfile.waterLow);
  Serial.print(F("watFill: "));  Serial.println(activeProfile.waterRefill);

  updateLCDTime();
  setLCDLine1(("Pet: " + activeProfile.name).c_str());
  Blynk.virtualWrite(V3, ("Pet: " + activeProfile.name).c_str());

  // Cap nhat sensor ngay sau khi doi profile
  int   w = readWaterLevel();
  float f = readFoodWeight();
  Blynk.virtualWrite(V0, w);
  if (f >= 0) Blynk.virtualWrite(V1, f);
}

