// ===================================================
// DISPENSE FOOD
// ===================================================

void dispenseFood() {
  if (isDispensing || isPumping) return;
  if (currentState == STATE_ERROR) return;

  float before = readFoodWeight();
  if (before < 0) {
    Serial.println(F("Loadcell Error - cannot dispense"));
    enterErrorState("Sensor Error!");
    return;
  }

  float target = activeProfile.foodTargetGram - before;
  if (target <= 0) {
    Blynk.virtualWrite(V3, F("Food sufficient"));
    setLCDLine1("Food OK");
    return;
  }

  isDispensing = true;
  currentState = STATE_DISPENSING;
  Blynk.virtualWrite(V3, F("Dispensing..."));
  setLCDLine1("Dispensing...");

  float dispensed     = 0;
  float lastDispensed = 0;
  int   safetyLoop    = 0;
  int   noChangeCount = 0;
  bool  jammed        = false;

  while (dispensed < target && safetyLoop < DISPENSE_SAFETY) {
    myServo.write(90);
    Blynk.run();
    yield();
    delay(500);
    myServo.write(0);
    delay(SETTLE_DELAY_MS);

    float current = readFoodWeight();
    if (current < 0) {
      Serial.println(F("Loadcell Error - during dispensing"));
      enterErrorState("Sensor Error!");
      return;
    }

    dispensed = current - before;

    if ((dispensed - lastDispensed) < 1.0) {
      noChangeCount++;
      if (noChangeCount >= NO_CHANGE_LIMIT) {
        jammed = true;
        Blynk.logEvent("food_jam",
          "Food jam or container empty. Please check the feeder.");
        break;
      }
    } else {
      noChangeCount = 0;
    }

    lastDispensed = dispensed;
    safetyLoop++;
  }

  myServo.write(0);

  if (dispensed > 0) {
    feedCountToday++;
    String t = getCurrentTime();
    Blynk.virtualWrite(V7, t);
    if (firebaseReady())
      Firebase.RTDB.setString(&fbdo, "/logs/lastFeed", t.c_str());
    syncLogs();
  }

  resetToIdle(jammed ? "Food Jam/Empty!" :
              (dispensed > 0 ? "OK - Ready" : "Check Feeder!"));
}

// ===================================================
// PUMP WATER
// ===================================================

void pumpWater() {
  if (isPumping || isDispensing) return;
  if (currentState == STATE_ERROR) return;

  isPumping    = true;
  currentState = STATE_PUMPING;
  Blynk.virtualWrite(V3, F("Refilling..."));
  setLCDLine1("Refilling...");

  int pct          = readWaterLevel();
  int attempts     = 0;
  int noRiseCount  = 0;
  int lastPct      = pct;
  bool sourceEmpty = false;

  while (pct < activeProfile.waterRefill && attempts < PUMP_MAX_ATTEMPTS) {
    digitalWrite(RELAY_PIN, HIGH);
    Blynk.virtualWrite(V5, F("ON"));
    Blynk.run();
    yield();
    delay(500);

    pct = readWaterLevel();

    if (pct <= lastPct) noRiseCount++;
    else                noRiseCount = 0;

    if (noRiseCount >= NO_RISE_LIMIT) {
      sourceEmpty = true;
      Blynk.logEvent("source_empty",
        "Water source is empty! Please refill.");
      break;
    }

    lastPct = pct;
    attempts++;
  }

  digitalWrite(RELAY_PIN, LOW);
  Blynk.virtualWrite(V5, F("OFF"));

  if (sourceEmpty) {
    resetToIdle("Refill Source!");
  } else if (attempts >= PUMP_MAX_ATTEMPTS) {
    resetToIdle("Check Pump!");
  } else {
    refillCountToday++;
    String t = getCurrentTime();
    Blynk.virtualWrite(V8, t);
    if (firebaseReady())
      Firebase.RTDB.setString(&fbdo, "/logs/lastRefill", t.c_str());
    syncLogs();
    resetToIdle("OK - Ready");
  }
}

// ===================================================
// MANUAL PUMP DETECT
// ===================================================

void checkManualPump() {
  if (currentState != STATE_PUMPING) return;
  if (!isPumping) return;
  if (digitalRead(RELAY_PIN) == LOW) return;
  if (millis() - manualLastCheck < 1500) return;
  manualLastCheck = millis();

  int pct = readWaterLevel();

  if (pct <= manualLastPct) manualNoRise++;
  else                      manualNoRise = 0;

  manualLastPct = pct;

  if (manualNoRise >= NO_RISE_LIMIT) {
    digitalWrite(RELAY_PIN, LOW);
    Blynk.virtualWrite(V4, 0);
    Blynk.virtualWrite(V5, F("OFF"));
    Blynk.logEvent("source_empty",
      "Water source is empty! Please refill.");
    manualNoRise = 0;
    resetToIdle("Refill Source!");
  }
}

// ===================================================
// NEW DAY
// ===================================================

void checkNewDay() {
  struct tm t;
  if (!getLocalTime(&t)) return;
  char today[12];
  strftime(today, sizeof(today), "%d/%m/%Y", &t);
  if (String(today) == lastDate) return;

  float currentWeight = readFoodWeight();

  if (foodWeightMorning > 0 && currentWeight > 0) {
    float ratio = (foodWeightMorning - currentWeight) / foodWeightMorning;
    if (ratio < 0.2)
      Blynk.logEvent("clean_food_bowl",
        "Food not consumed yesterday. Please clean the food bowl.");
  }

  if (refillCountToday >= 5)
    Blynk.logEvent("clean_water_bowl",
      "Water refilled many times. Please clean water bowl.");

  foodWeightMorning = currentWeight;
  feedCountToday    = 0;
  refillCountToday  = 0;
  lastDate          = String(today);
}

// ===================================================
// PERIODIC CHECKS
// ===================================================

void checkFood() {
  if (currentState == STATE_ERROR) return;
  float foodGram = readFoodWeight();
  if (foodGram < 0) return;
  Blynk.virtualWrite(V1, foodGram);

  if (foodGram < activeProfile.foodLowGram) {
    if (!foodEventSent) {
      Blynk.logEvent("food_low", "Food is low, dispensing...");
      foodEventSent = true;
    }
    dispenseFood();
  } else {
    foodEventSent = false;
  }
}

void checkWater() {
  if (currentState == STATE_ERROR) return;
  int waterPct = readWaterLevel();
  Blynk.virtualWrite(V0, waterPct);

  if (waterPct < activeProfile.waterLow) {
    if (!waterEventSent) {
      Blynk.logEvent("water_low", "Water is low, refilling...");
      waterEventSent = true;
    }
    pumpWater();
  } else {
    waterEventSent = false;
  }
}

void checkAndUpdate() {
  checkNewDay();
  Blynk.virtualWrite(V6, F("Online"));
  checkWater();
  checkFood();
}

// ===================================================
// BLYNK CALLBACKS
// ===================================================

BLYNK_WRITE(V2) {
  if (param.asInt() == 1 && !isDispensing && !isPumping
      && currentState != STATE_ERROR)
    shouldFeed = true;
}

BLYNK_WRITE(V4) {
  if (isDispensing || currentState == STATE_ERROR) {
    Blynk.virtualWrite(V4, 0);
    return;
  }
  if (param.asInt()) {
    if (isPumping) return;
    digitalWrite(RELAY_PIN, HIGH);
    isPumping       = true;
    currentState    = STATE_PUMPING;
    manualLastPct   = readWaterLevel();
    manualNoRise    = 0;
    manualLastCheck = millis();
    Blynk.virtualWrite(V3, F("Manual Pump ON"));
    Blynk.virtualWrite(V5, F("ON"));
  } else {
    digitalWrite(RELAY_PIN, LOW);
    Blynk.virtualWrite(V5, F("OFF"));
    manualNoRise = 0;
    resetToIdle();
  }
}

BLYNK_WRITE(V12) {
  if (currentState == STATE_ERROR) currentState = STATE_IDLE;
  loadProfile(String(param.asInt()));
  checkWater();
  checkFood();
}

// ===================================================
// SETUP
// ===================================================

void setup() {
  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0);
  Serial.begin(115200);
  delay(500);

  pinMode(WATER_SENSOR_VCC_PIN, OUTPUT);
  digitalWrite(WATER_SENSOR_VCC_PIN, LOW);
  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);
  pinMode(RESET_PIN, INPUT_PULLUP);

  myServo.attach(SERVO_PIN);
  myServo.write(0);

  scale.begin(DOUT_PIN, SCK_PIN);
  scale.set_scale(SCALE_FACTOR);
  scale.tare();

  lcd.init();
  lcd.backlight();
  setLCDLine0("Pet Feeder IoT");
  setLCDLine1("Connecting...");

  WiFiManager wifiManager;
  wifiManager.setConfigPortalTimeout(180);

  if (digitalRead(RESET_PIN) == LOW) {
    wifiManager.resetSettings();
    delay(1000);
    ESP.restart();
  }

  wifiManager.setAPCallback([](WiFiManager* wm) {
    setLCDLine0("Connect WiFi:");
    setLCDLine1("PetFeeder-Setup");
  });

  if (!wifiManager.autoConnect("PetFeeder-Setup")) {
    ESP.restart();
  }

  Blynk.config(BLYNK_AUTH_TOKEN);
  Blynk.connect();

  configTime(7 * 3600, 0, "pool.ntp.org");
  delay(2000);

  fbConfig.api_key               = FIREBASE_API_KEY;
  fbConfig.database_url          = FIREBASE_DB_URL;
  fbConfig.token_status_callback = tokenStatusCallback;

  if (Firebase.signUp(&fbConfig, &fbAuth, "", "")) {
    Serial.println(F("Firebase OK"));
  } else {
    Serial.println(F("Firebase failed"));
  }

  Firebase.begin(&fbConfig, &fbAuth);
  Firebase.reconnectWiFi(true);

  // Cho Firebase san sang truoc khi doc
  int waitCount = 0;
  while (!firebaseReady() && waitCount < 10) {
    delay(500);
    waitCount++;
  }

  if (Firebase.RTDB.getString(&fbdo, "/activeProfile"))
    loadProfile(fbdo.stringData());
  else
    loadProfile("1");

  struct tm t;
  if (getLocalTime(&t)) {
    char today[12];
    strftime(today, sizeof(today), "%d/%m/%Y", &t);
    lastDate          = String(today);
    foodWeightMorning = readFoodWeight();
  }

  Blynk.virtualWrite(V5, F("OFF"));
  Blynk.virtualWrite(V6, F("Online"));
  Blynk.virtualWrite(V7, F("--"));
  Blynk.virtualWrite(V8, F("--"));
  Blynk.virtualWrite(V3, F("Monitoring"));

  setLCDLine0("Pet Feeder IoT");
  setLCDLine1(("Pet: " + activeProfile.name).c_str());
  delay(1500);

  timer.setInterval(30000L, checkAndUpdate);
  timer.setInterval(1000L,  updateLCDTime);

  Serial.println(F("=== Pet Feeder IoT Ready ==="));
}

// ===================================================
// LOOP
// ===================================================

void loop() {
  Blynk.run();
  timer.run();
  checkManualPump();

  if (shouldFeed && !isDispensing && !isPumping
      && currentState != STATE_ERROR) {
    shouldFeed = false;
    dispenseFood();
  }
}
