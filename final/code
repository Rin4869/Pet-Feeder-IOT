}

// ===================================================
// LOAD PROFILE — FIX 3: Doc doc lap tung truong
// Neu loi thi dung gia tri mac dinh, KHONG enterErrorState
// ===================================================

void loadProfile() {
  if (!firebaseReady()) {
    Serial.println(F("Firebase not ready, use default profile"));
    // FIX 3: Dung gia tri mac dinh thay vi enterErrorState
    pendingProfile = activeProfile;
    syncProfileToBlynk();
    return;
  }

  bool   ok      = false;
  int    retries = 0;
  FirebaseJson     json;
  FirebaseJsonData result;

  while (!ok && retries < 3) {
    if (Firebase.RTDB.getJSON(&fbdo, "/profile")) {
      ok = true;
    } else {
      retries++;
      Serial.print(F("Profile load retry: "));
      Serial.println(retries);
      delay(500);
    }
  }

  if (!ok) {
    Serial.println(F("Profile load failed, use default profile"));
    // FIX 3: Dung gia tri mac dinh thay vi enterErrorState
    pendingProfile = activeProfile;
    syncProfileToBlynk();
    return;
  }

  json.setJsonData(fbdo.jsonString());

  // FIX 3: Doc doc lap tung truong — loi truong nao thi dung mac dinh truong do
  if (json.get(result, "name") && result.success)
    activeProfile.name = result.stringValue;

  if (json.get(result, "foodLow") && result.success)
    activeProfile.foodLowGram = result.intValue;

  if (json.get(result, "foodTarget") && result.success)
    activeProfile.foodTargetGram = result.intValue;

  if (json.get(result, "waterLow") && result.success)
    activeProfile.waterLow = result.intValue;

  if (json.get(result, "waterRefill") && result.success)
    activeProfile.waterRefill = result.intValue;

  if (json.get(result, "feedInterval") && result.success)
    activeProfile.feedIntervalHour = result.intValue;

  pendingProfile = activeProfile;

  firstFeedDone  = false;
  lastFeedMillis = 0;

  Serial.print(F("Profile: "));  Serial.println(activeProfile.name);
  Serial.print(F("foodLow: "));  Serial.println(activeProfile.foodLowGram);
  Serial.print(F("foodTgt: "));  Serial.println(activeProfile.foodTargetGram);
  Serial.print(F("watLow: "));   Serial.println(activeProfile.waterLow);
  Serial.print(F("watFill: "));  Serial.println(activeProfile.waterRefill);
  Serial.print(F("interval: ")); Serial.println(activeProfile.feedIntervalHour);

  updateLCDTime();
  setLCDLine1(("Pet: " + activeProfile.name).c_str());
  Blynk.virtualWrite(V3, ("Pet: " + activeProfile.name).c_str());
  syncProfileToBlynk();

  int   w = readWaterLevel();
  float f = readFoodWeight();
  Blynk.virtualWrite(V0, w);
  if (f >= 0) Blynk.virtualWrite(V1, f);
}

