String getCurrentTime() {
  struct tm t;
  if (!getLocalTime(&t)) return "--:--";
  char buf[20];
  strftime(buf, sizeof(buf), "%H:%M %d/%m/%Y", &t);
  return String(buf);
}

String truncate(String s) {
  if ((int)s.length() > LCD_WIDTH) s = s.substring(0, LCD_WIDTH);
  while ((int)s.length() < LCD_WIDTH) s += ' ';
  return s;
}

void setLCDLine0(const char* text) {
  lcd.setCursor(0, 0);
  lcd.print(truncate(String(text)));
}

void setLCDLine1(const char* text) {
  lcd.setCursor(0, 1);
  lcd.print(truncate(String(text)));
}

void updateLCDTime() {
  if (currentState != STATE_IDLE) return;
  struct tm t;
  char buf[17] = "--:-- --/--/----";
  if (getLocalTime(&t))
    strftime(buf, sizeof(buf), "%H:%M %d/%m/%Y", &t);
  setLCDLine0(buf);
}

void resetToIdle(const char* lcdMsg = "OK - Ready") {
  currentState = STATE_IDLE;
  isDispensing = false;
  isPumping    = false;
  Blynk.virtualWrite(V3, F("Monitoring"));
  setLCDLine1(lcdMsg);
}

// FIX 4: Ghi lai thoi diem vao STATE_ERROR de Auto-Recovery theo doi
void enterErrorState(const char* reason) {
  if (currentState != STATE_ERROR) {
    errorEnteredAt = millis();  // chi ghi lan dau vao loi
  }
  currentState = STATE_ERROR;
  isDispensing = false;
  isPumping    = false;
  digitalWrite(RELAY_PIN, LOW);
  myServo.write(0);
  Serial.print(F("ERROR: "));
  Serial.println(reason);
  Blynk.virtualWrite(V3, reason);
  setLCDLine1(reason);
}

bool isTimeToFeed() {
  if (!firstFeedDone) return true;
  unsigned long intervalMs =
    (unsigned long)activeProfile.feedIntervalHour * 3600000UL;
  return (millis() - lastFeedMillis) >= intervalMs;
}

// FIX 1: Kiem tra Pump Cooldown
bool isPumpReady() {
  if (!firstPumpDone) return true;
  return (millis() - lastPumpMillis) >= PUMP_COOLDOWN_MS;
}

// ===================================================
// SENSORS
// ===================================================

int readWaterLevel() {
  digitalWrite(WATER_SENSOR_VCC_PIN, HIGH);
  delay(100);
  int raw = analogRead(WATER_SENSOR_PIN);
  digitalWrite(WATER_SENSOR_VCC_PIN, LOW);
  return constrain(map(raw, WATER_MIN, WATER_MAX, 0, 100), 0, 100);
}

float readFoodWeight() {
  if (!scale.is_ready()) return -1;
  float w = scale.get_units(5);
  if (isnan(w)) return -1;
  return w;
}

